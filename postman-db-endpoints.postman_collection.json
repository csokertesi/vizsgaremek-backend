{
  "info": {
    "_postman_id": "7c28d6d3-4a7f-4bf4-a6c9-6d5496da0c6e",
    "name": "Vizsgaremek Backend - Database Endpoints",
    "description": "Collection for testing all database-related endpoints in the Vizsgaremek backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "jwtToken", "value": "" },
    { "key": "siteId", "value": "1" },
    { "key": "deviceId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "postmanRunId", "value": "" },
    { "key": "postmanUsername", "value": "" },
    { "key": "postmanEmail", "value": "" },
    { "key": "postmanSiteName", "value": "" },
    { "key": "postmanSiteId", "value": "" },
    { "key": "postmanDeviceName", "value": "" },
    { "key": "postmanDeviceId", "value": "" },
    { "key": "managedUserId", "value": "" },
    { "key": "registeredUserToken", "value": "" },
    { "key": "adminIdentifier", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "encryptedData", "value": "replace-with-base64url-encrypted-payload" },
    { "key": "fromDateIso", "value": "2026-01-01T00:00:00.000Z" },
    { "key": "toDateIso", "value": "2026-12-31T23:59:59.999Z" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const reqName = pm.info.requestName;",
          "let runId = pm.collectionVariables.get('postmanRunId');",
          "if (!runId) {",
          "  runId = String(Date.now());",
          "  pm.collectionVariables.set('postmanRunId', runId);",
          "}",
          "",
          "if (reqName === 'Register User') {",
          "  pm.collectionVariables.set('postmanUsername', `postman_user_${runId}`);",
          "  pm.collectionVariables.set('postmanEmail', `postman_user_${runId}@example.com`);",
          "}",
          "",
          "if (reqName === 'Create Site (ADMIN)') {",
          "  pm.collectionVariables.set('postmanSiteName', `Postman Site ${runId}`);",
          "}",
          "",
          "if (reqName === 'Create Device (ADMIN)') {",
          "  pm.collectionVariables.set('postmanDeviceName', `Postman Device ${runId}`);",
          "}",
          "",
          "if (reqName === 'Update Site (ADMIN)' && !pm.collectionVariables.get('postmanSiteId')) {",
          "  pm.collectionVariables.set('postmanSiteId', pm.collectionVariables.get('siteId'));",
          "}",
          "",
          "if (reqName === 'Update Device (ADMIN)' && !pm.collectionVariables.get('postmanDeviceId')) {",
          "  pm.collectionVariables.set('postmanDeviceId', pm.collectionVariables.get('deviceId'));",
          "}",
          "",
          "if ((reqName === 'Update User Role (ADMIN)' || reqName === 'Delete User (ADMIN)') && !pm.collectionVariables.get('managedUserId')) {",
          "  pm.collectionVariables.set('managedUserId', pm.collectionVariables.get('userId'));",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const reqName = pm.info.requestName;",
          "const code = pm.response.code;",
          "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
          "const isJson = contentType.includes('application/json');",
          "const isCsv = contentType.includes('text/csv');",
          "const isHtml = contentType.includes('text/html');",
          "",
          "const expectedCodesByRequest = {",
          "  'Login (stores jwtToken)': [200, 201],",
          "  'Register User': [200, 201],",
          "  'Get Profile': [200],",
          "  'Get All Sites': [200],",
          "  'Get Dashboard Data': [200],",
          "  'Get Site By ID': [200],",
          "  'Create Site (ADMIN)': [200, 201],",
          "  'Update Site (ADMIN)': [200],",
          "  'Delete Site (ADMIN)': [200],",
          "  'Get All Devices (ADMIN)': [200],",
          "  'Get Device By ID (ADMIN)': [200],",
          "  'Create Device (ADMIN)': [200, 201],",
          "  'Update Device (ADMIN)': [200],",
          "  'Delete Device (ADMIN)': [200],",
          "  'Get Recent Measurements (JWT)': [200],",
          "  'Get Measurements By Device (JWT)': [200],",
          "  'Submit Encrypted Device Measurement': [200, 201, 400, 401],",
          "  'Create Measurement (JWT)': [200, 201],",
          "  'Export Measurements CSV (JWT)': [200],",
          "  'Get Evaluations By Site': [200],",
          "  'Generate Evaluation': [200, 201],",
          "  'Get Stats (ADMIN)': [200],",
          "  'Get Users (ADMIN)': [200],",
          "  'Update User Role (ADMIN)': [200],",
          "  'Delete User (ADMIN)': [200],",
          "  'Get Device Edit Page (DB-backed view)': [200]",
          "};",
          "",
          "const expected = expectedCodesByRequest[reqName] || [200, 201];",
          "pm.test(`${reqName} returns expected status`, function () {",
          "  pm.expect(expected).to.include(code);",
          "});",
          "",
          "pm.test(`${reqName} responds within 3 seconds`, function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});",
          "",
          "if (isJson) {",
          "  const body = pm.response.json();",
          "  pm.test(`${reqName} has JSON response`, function () {",
          "    pm.expect(body).to.not.equal(null);",
          "  });",
          "",
          "  if (reqName === 'Login (stores jwtToken)' || reqName === 'Register User') {",
          "    pm.test(`${reqName} returns access token`, function () {",
          "      pm.expect(body.access_token).to.be.a('string').and.not.empty;",
          "    });",
          "",
          "    if (reqName === 'Login (stores jwtToken)') {",
          "      pm.collectionVariables.set('jwtToken', body.access_token);",
          "    }",
          "",
          "    if (reqName === 'Register User') {",
          "      pm.collectionVariables.set('registeredUserToken', body.access_token);",
          "    }",
          "",
          "    if (reqName === 'Register User') {",
          "      const token = body.access_token;",
          "      const parts = token.split('.');",
          "      if (parts.length === 3) {",
          "        try {",
          "          const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
          "          if (payload.sub) {",
          "            pm.collectionVariables.set('managedUserId', String(payload.sub));",
          "          }",
          "        } catch (e) {}",
          "      }",
          "    }",
          "  }",
          "",
          "  if (reqName === 'Get All Sites' && Array.isArray(body) && body.length > 0 && body[0].id) {",
          "    pm.collectionVariables.set('siteId', String(body[0].id));",
          "  }",
          "",
          "  if (reqName === 'Create Site (ADMIN)' && body.id) {",
          "    pm.collectionVariables.set('postmanSiteId', String(body.id));",
          "  }",
          "",
          "  if (reqName === 'Get All Devices (ADMIN)' && Array.isArray(body) && body.length > 0 && body[0].id) {",
          "    pm.collectionVariables.set('deviceId', String(body[0].id));",
          "  }",
          "",
          "  if (reqName === 'Create Device (ADMIN)' && body.id) {",
          "    pm.collectionVariables.set('postmanDeviceId', String(body.id));",
          "  }",
          "",
          "  if (reqName === 'Get Users (ADMIN)' && Array.isArray(body)) {",
          "    const chosen = body.find((u) => u && u.role !== 'ADMIN') || body[0];",
          "    if (chosen && chosen.id) {",
          "      pm.collectionVariables.set('managedUserId', String(chosen.id));",
          "      pm.collectionVariables.set('userId', String(chosen.id));",
          "    }",
          "  }",
          "}",
          "",
          "if (reqName === 'Export Measurements CSV (JWT)') {",
          "  pm.test('CSV export response content-type is text/csv', function () {",
          "    pm.expect(isCsv).to.eql(true);",
          "  });",
          "  pm.test('CSV export has header row', function () {",
          "    const text = pm.response.text();",
          "    pm.expect(text).to.include('id,device_id,site_id,timestamp');",
          "  });",
          "}",
          "",
          "if (reqName === 'Get Device Edit Page (DB-backed view)') {",
          "  pm.test('Edit page returns HTML', function () {",
          "    pm.expect(isHtml).to.eql(true);",
          "  });",
          "}"
        ]
      }
    }
  ],
